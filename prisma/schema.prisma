// =============================================================================
// PRISMA 7 - SCHEMA JOURNAL DE TRADING
// Provider : PostgreSQL (Neon) | Déploiement : Vercel
// Multi-user with whitelist, powered by BetterAuth
// =============================================================================

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =============================================================================
// BETTER-AUTH — Core tables
// =============================================================================

model WhitelistedEmail {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@map("whitelisted_email")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  role          Role      @default(USER)

  sessions      Session[]
  accounts      Account[]

  // App relations
  setups          Setup[]
  trades          Trade[]
  tradingSessions TradingSession[]
  journalEntries  JournalEntry[]
  equitySnapshots EquitySnapshot[]
  tags            Tag[]
  backtests       Backtest[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// =============================================================================
// ENUMS
// =============================================================================

enum Role {
  USER
  ADMIN
}

enum Direction {
  LONG
  SHORT
}

enum AssetClass {
  FOREX
  CRYPTO
  STOCKS
  FUTURES
  OPTIONS
  CFD
  COMMODITIES
  INDICES
  BONDS
}

enum TradeStatus {
  OPEN
  PARTIAL
  CLOSED
  CANCELLED
}

enum Timeframe {
  M1
  M5
  M15
  M30
  H1
  H4
  D1
  W1
  MN
}

enum TradeOutcome {
  WIN
  LOSS
  BREAKEVEN
}

enum MoodLevel {
  EXCELLENT
  GOOD
  NEUTRAL
  BAD
  TERRIBLE
}

enum EquitySnapshotType {
  DAILY
  WEEKLY
  MONTHLY
  MANUAL
  DEPOSIT
  WITHDRAWAL
}

enum JournalEntryType {
  REFLECTION
  LESSON
  PLAN
  IDEA
  RULE
  FREE
}

enum ReviewStatus {
  PENDING
  REVIEWED
  ARCHIVED
}

// =============================================================================
// ENUMS ICT / SMC
// =============================================================================

enum IctModel {
  ICT_2022
  SILVER_BULLET
  JUDAS_SWING
  LONDON_OPEN_RECAP
  POWER_OF_3
  BREAKER_BLOCK
  MITIGATION_BLOCK
  PROPULSION_BLOCK
  FVG_FILL
  OTE
  TURTLE_SOUP
  SCALP
  OTHER
}

enum PoiType {
  ORDER_BLOCK_BULL
  ORDER_BLOCK_BEAR
  BREAKER_BLOCK_BULL
  BREAKER_BLOCK_BEAR
  FVG_BULL
  FVG_BEAR
  IFVG_BULL
  IFVG_BEAR
  MITIGATION_BLOCK_BULL
  MITIGATION_BLOCK_BEAR
  LIQUIDITY_VOID
  PREMIUM_ARRAY
  DISCOUNT_ARRAY
  EQUILIBRIUM
  WEEKLY_OPEN
  DAILY_OPEN
  MIDNIGHT_OPEN
  LONDON_OPEN
  ASIA_HIGH
  ASIA_LOW
  PREV_DAY_HIGH
  PREV_DAY_LOW
  PREV_WEEK_HIGH
  PREV_WEEK_LOW
}

enum MarketSession {
  ASIA
  LONDON
  LONDON_CLOSE
  NEW_YORK_AM
  NEW_YORK_PM
  SILVER_BULLET_AM
  SILVER_BULLET_PM
  OVERLAP
  OFF_HOURS
}

enum MarketBias {
  BULLISH
  BEARISH
  NEUTRAL
}

enum MarketStructure {
  HH_HL
  LH_LL
  RANGE
  BOS_UP
  BOS_DOWN
  CHOCH_UP
  CHOCH_DOWN
}

enum LiquidityType {
  BSL
  SSL
  BOTH
  NONE
}

// =============================================================================
// MODEL : Setup / Playbook
// =============================================================================
model Setup {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  entryRules   String?
  exitRules    String?
  riskRules    String?
  notes        String?
  isActive     Boolean  @default(true)
  winRate      Decimal? @db.Decimal(5, 2)
  avgRMultiple Decimal? @db.Decimal(8, 4)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  trades    Trade[]
  backtests Backtest[]

  @@unique([userId, name])
  @@index([userId])
  @@index([isActive])
}

// =============================================================================
// MODEL : Tag
// =============================================================================
model Tag {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime @default(now())

  trades TradeTag[]

  @@unique([userId, name])
  @@index([userId])
}

model TradeTag {
  tradeId String
  tagId   String

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([tradeId, tagId])
  @@index([tagId])
}

// =============================================================================
// MODEL : TradingSession
// =============================================================================
model TradingSession {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime   @db.Date
  preMood        MoodLevel?
  prePlan        String?
  energyLevel    Int?
  sleepHours     Decimal?   @db.Decimal(4, 1)
  postMood       MoodLevel?
  postNotes      String?
  lessonLearned  String?
  totalPnl       Decimal?   @db.Decimal(15, 4)
  tradeCount     Int?       @default(0)
  winCount       Int?       @default(0)
  lossCount      Int?       @default(0)
  breakevenCount Int?       @default(0)
  ruleAdherence  Int?
  hadRevenge     Boolean    @default(false)
  hadFomo        Boolean    @default(false)
  wasOvertraded  Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  trades         Trade[]
  screenshots    Screenshot[]
  journalEntries JournalEntry[]

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
}

// =============================================================================
// MODEL : Trade
// =============================================================================
model Trade {
  id              String       @id @default(cuid())
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol          String
  assetClass      AssetClass
  direction       Direction
  status          TradeStatus  @default(OPEN)
  reviewStatus    ReviewStatus @default(PENDING)
  sessionId       String?
  session         TradingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  setupId         String?
  setup           Setup?       @relation(fields: [setupId], references: [id], onDelete: SetNull)
  entryTime       DateTime
  exitTime        DateTime?
  durationSec     Int?
  timeframeTrend  Timeframe?
  timeframeEntry  Timeframe?
  entryPrice      Decimal      @db.Decimal(20, 8)
  exitPrice       Decimal?     @db.Decimal(20, 8)
  stopLoss        Decimal?     @db.Decimal(20, 8)
  takeProfit1     Decimal?     @db.Decimal(20, 8)
  takeProfit2     Decimal?     @db.Decimal(20, 8)
  takeProfit3     Decimal?     @db.Decimal(20, 8)
  quantity        Decimal      @db.Decimal(20, 8)
  lotSize         Decimal?     @db.Decimal(10, 4)
  riskPercent     Decimal?     @db.Decimal(6, 4)
  riskAmount      Decimal?     @db.Decimal(15, 4)
  accountCurrency String       @default("USD")
  commission      Decimal?     @db.Decimal(12, 4)
  swap            Decimal?     @db.Decimal(12, 4)
  slippage        Decimal?     @db.Decimal(10, 4)
  pnlGross        Decimal?     @db.Decimal(15, 4)
  pnlNet          Decimal?     @db.Decimal(15, 4)
  rMultiple       Decimal?     @db.Decimal(8, 4)
  pipsResult      Decimal?     @db.Decimal(10, 2)
  mae             Decimal?     @db.Decimal(20, 8)
  mfe             Decimal?     @db.Decimal(20, 8)
  maeR            Decimal?     @db.Decimal(8, 4)
  mfeR            Decimal?     @db.Decimal(8, 4)
  efficiency      Decimal?     @db.Decimal(6, 2)
  outcome         TradeOutcome?
  marketContext   String?
  catalyst        String?
  qualityScore    Int?
  preTradeNotes   String?
  postTradeNotes  String?
  executionNotes  String?
  mistakeNotes    String?
  isRevengeTraded Boolean      @default(false)
  isFomo          Boolean      @default(false)
  isImpulsive     Boolean      @default(false)
  followedRules   Boolean?
  planAdherence   PlanAdherence?
  emotion         EmotionLevel?
  brokerTradeId   String?
  brokerName      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  ictContext     IctContext?
  tags           TradeTag[]
  executions     TradeExecution[]
  screenshots    Screenshot[]
  journalEntries JournalEntry[]

  @@index([userId])
  @@index([entryTime])
  @@index([symbol])
  @@index([assetClass])
  @@index([status])
  @@index([setupId])
  @@index([sessionId])
  @@index([direction])
  @@index([outcome])
  @@index([reviewStatus])
  @@index([assetClass, entryTime])
  @@index([symbol, entryTime])
}

// =============================================================================
// MODEL : TradeExecution
// =============================================================================
model TradeExecution {
  id         String   @id @default(cuid())
  tradeId    String
  trade      Trade    @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  side       String
  price      Decimal  @db.Decimal(20, 8)
  quantity   Decimal  @db.Decimal(20, 8)
  commission Decimal? @db.Decimal(12, 4)
  swap       Decimal? @db.Decimal(12, 4)
  executedAt DateTime
  notes      String?

  @@index([tradeId])
  @@index([executedAt])
}

// =============================================================================
// MODEL : IctContext
// =============================================================================
model IctContext {
  id       String @id @default(cuid())
  tradeId  String @unique
  trade    Trade  @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  ictModel           IctModel?
  ictModelNotes      String?
  poi                PoiType?
  poiTimeframe       Timeframe?
  poiNotes           String?
  marketSession      MarketSession?
  biasHTF            MarketBias?
  biasMTF            MarketBias?
  biasLTF            MarketBias?
  structureHTF       MarketStructure?
  structureLTF       MarketStructure?
  hasChoch           Boolean @default(false)
  hasBos             Boolean @default(false)
  liquiditySwept     LiquidityType?
  liquidityTargeted  LiquidityType?
  liquidityNotes     String?
  hasFvg             Boolean @default(false)
  hasOrderBlock      Boolean @default(false)
  hasBreakerBlock    Boolean @default(false)
  hasInversion       Boolean @default(false)
  hasImbalance       Boolean @default(false)
  isOte              Boolean @default(false)
  isPremium          Boolean @default(false)
  isDiscount         Boolean @default(false)
  isAtEquilibrium    Boolean @default(false)
  usedWeeklyOpen     Boolean @default(false)
  usedDailyOpen      Boolean @default(false)
  usedMidnightOpen   Boolean @default(false)
  usedAsiaHigh       Boolean @default(false)
  usedAsiaLow        Boolean @default(false)
  usedPdh            Boolean @default(false)
  usedPdl            Boolean @default(false)
  waitedKillZone     Boolean @default(false)
  hadLtfConfirmation Boolean @default(false)
  entryType          String?
  confluenceNotes    String?
  mistakeNotes       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([ictModel])
  @@index([poi])
  @@index([marketSession])
  @@index([biasHTF])
}

// =============================================================================
// MODEL : Screenshot
// =============================================================================
model Screenshot {
  id        String   @id @default(cuid())
  tradeId   String?
  trade     Trade?   @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  sessionId String?
  session   TradingSession? @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  url        String
  storageKey String?
  filename   String?
  mimeType   String?
  sizeBytes  Int?
  width      Int?
  height     Int?
  timeframe  Timeframe?
  chartType  String?
  caption    String?
  takenAt    DateTime?
  createdAt  DateTime @default(now())

  @@index([tradeId])
  @@index([sessionId])
}

// =============================================================================
// MODEL : EquitySnapshot
// =============================================================================
model EquitySnapshot {
  id               String             @id @default(cuid())
  userId           String
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshotType     EquitySnapshotType @default(DAILY)
  date             DateTime           @db.Date
  equity           Decimal            @db.Decimal(18, 4)
  totalDeposits    Decimal?           @db.Decimal(18, 4)
  totalWithdrawals Decimal?           @db.Decimal(18, 4)
  tradingCapital   Decimal?           @db.Decimal(18, 4)
  currency         String             @default("USD")
  drawdown         Decimal?           @db.Decimal(8, 4)
  drawdownAmount   Decimal?           @db.Decimal(15, 4)
  peakEquity       Decimal?           @db.Decimal(18, 4)
  periodPnl        Decimal?           @db.Decimal(15, 4)
  periodTrades     Int?
  periodWins       Int?
  periodLosses     Int?
  notes            String?
  createdAt        DateTime           @default(now())

  @@unique([userId, date, snapshotType])
  @@index([userId])
  @@index([date])
  @@index([snapshotType])
}

// =============================================================================
// ENUMS : Backtest
// =============================================================================

enum BacktestStatus {
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

// =============================================================================
// MODEL : Backtest
// =============================================================================
model Backtest {
  id          String @id @default(cuid())
  userId      String
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Identité
  name        String
  description String?
  instrument  String              // "NQ", "ES", "EUR/USD"…
  timeframe   Timeframe?
  setupId     String?
  setup       Setup?  @relation(fields: [setupId], references: [id], onDelete: SetNull)

  // Période backtestée
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date

  // Capital & risque
  initialCapital Float @default(10000)
  riskPerTrade   Float @default(1)   // % du capital par trade

  // Statut
  status BacktestStatus @default(IN_PROGRESS)

  // Notes libres
  notes String?

  trades BacktestTrade[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([setupId])
  @@index([status])
  @@index([userId, status])
}

// =============================================================================
// MODEL : BacktestTrade
// =============================================================================
model BacktestTrade {
  id         String   @id @default(cuid())
  backtestId String
  backtest   Backtest @relation(fields: [backtestId], references: [id], onDelete: Cascade)

  tradeNumber Int // numéro séquentiel dans le backtest

  // Timing
  entryDate DateTime
  exitDate  DateTime?

  // Prix
  entryPrice Float
  exitPrice  Float?
  stopLoss   Float?
  takeProfit Float?

  // Direction & résultat
  direction Direction
  outcome   TradeOutcome?

  // R-multiple (+2.5R, -1R…)
  rMultiple Float?

  // P&L
  pnlPoints  Float?
  pnlDollars Float?

  // Taille de position
  quantity Float @default(1)

  // ── Contexte de marché ──────────────────────────────────────────────────
  marketSession   MarketSession?
  timeframeEntry  Timeframe?      // timeframe d'entrée (ex: M5 pour l'exécution)
  timeframeTrend  Timeframe?      // timeframe de tendance (ex: H1 pour le bias)

  // ── ICT / SMC ───────────────────────────────────────────────────────────
  ictModel        IctModel?       // modèle utilisé : Silver Bullet, OTE, FVG Fill…
  poi             PoiType?        // point d'intérêt : Order Block, FVG, Breaker…
  biasHTF         MarketBias?     // biais higher timeframe (D1/W1)
  biasMTF         MarketBias?     // biais mid timeframe (H1/H4)
  marketStructure MarketStructure? // structure au moment de l'entrée
  liquiditySwept  LiquidityType?  // liquidité balayée avant l'entrée (BSL/SSL)

  // ── Comportement psychologique ──────────────────────────────────────────
  isFomo          Boolean @default(false)  // trade pris par peur de rater
  isRevenge       Boolean @default(false)  // trade de revanche après une perte
  isImpulsive     Boolean @default(false)  // entrée sans attendre la confirmation
  followedRules   Boolean?                 // a-t-on respecté les règles du setup ?

  // Qualité du trade (1-5)
  grade Int?

  // Notes & tags libres
  notes String?
  tags  String[]

  // Screenshot URL (legacy single URL — kept for backwards compat)
  screenshotUrl String?

  // ── Scénarios alternatifs de sortie ─────────────────────────────────────
  outcome1R    TradeOutcome? // résultat si sorti à 1R
  rMultiple1R  Float?        // R réalisé dans ce scénario (ex: +1.0 ou -0.8)
  outcome15R   TradeOutcome? // résultat si sorti à 1.5R
  rMultiple15R Float?        // R réalisé dans ce scénario

  createdAt DateTime @default(now())

  media BacktestTradeMedia[]

  @@index([backtestId])
  @@index([backtestId, tradeNumber])
  @@index([backtestId, outcome])
  @@index([backtestId, marketSession])
  @@index([backtestId, ictModel])
}

// =============================================================================
// MODEL : BacktestTradeMedia
// =============================================================================
model BacktestTradeMedia {
  id      String       @id @default(cuid())
  tradeId String
  trade   BacktestTrade @relation(fields: [tradeId], references: [id], onDelete: Cascade)

  // Storage
  url        String   // public URL (R2 / CDN)
  storageKey String   // object key in the R2 bucket (for deletion)
  filename   String?
  mimeType   String?
  sizeBytes  Int?

  // Optional metadata
  caption String?

  createdAt DateTime @default(now())

  @@index([tradeId])
  @@map("backtest_trade_media")
}

// =============================================================================
// ENUMS : PlanAdherence / EmotionLevel (used on Trade)
// =============================================================================

enum PlanAdherence {
  YES
  PARTIAL
  NO
}

enum EmotionLevel {
  CONFIDENT
  CALM
  NEUTRAL
  ANXIOUS
  FEARFUL
  GREEDY
  FRUSTRATED
  EUPHORIC
}

// =============================================================================
// MODEL : JournalEntry
// =============================================================================
model JournalEntry {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      JournalEntryType @default(FREE)
  title     String?
  content   String

  tradeId   String?
  trade     Trade?          @relation(fields: [tradeId], references: [id], onDelete: SetNull)
  sessionId String?
  session   TradingSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  mood       MoodLevel?
  importance Int?      @default(3)
  isPinned   Boolean   @default(false)
  entryDate  DateTime  @default(now()) @db.Date
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId])
  @@index([type])
  @@index([entryDate])
  @@index([tradeId])
  @@index([sessionId])
  @@index([isPinned])
}
