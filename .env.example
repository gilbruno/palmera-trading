# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/myjournal"

# ─── BetterAuth ───────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET="your-secret-here"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
# Found in: Cloudflare dashboard → R2 → Manage R2 API tokens
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="myjournal-media"

# Public URL for your R2 bucket.
# Option A — Cloudflare R2 public bucket domain:
#   https://<bucket-name>.<account-id>.r2.dev
# Option B — Custom domain configured in R2 settings:
#   https://media.yourdomain.com
R2_PUBLIC_URL="https://your-bucket.your-account-id.r2.dev"
